<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/sheet_bg"
    android:orientation="vertical"
    android:padding="24dp"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:background="@color/border"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp" />

    <!-- Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Analysis Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Similarity threshold -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Similarity threshold"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvThreshold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sliderThreshold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <!-- Min match duration -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Min match duration"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvMinDur"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sliderMinDur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <!-- Max gap -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Max gap within match"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvMaxGap"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sliderMaxGap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <!-- Match density -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Match density"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvDensity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sliderDensity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <!-- Frame sample rate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Frame sample rate"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvFrameRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sliderFrameRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <!-- Audio sample rate -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Audio sample rate"
                    android:textSize="13sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tvAudioRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/sliderAudioRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnApply"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Apply Settings"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textAllCaps="false"
        android:backgroundTint="@color/primary"
        android:textColor="@color/white" />

</LinearLayout>
