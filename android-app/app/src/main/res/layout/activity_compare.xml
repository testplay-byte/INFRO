<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Compare Videos"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- Mode selector -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COMPARISON MODE"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <Button
                android:id="@+id/btnAudio"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Audio"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnVideo"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Video"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp" />

            <Button
                android:id="@+id/btnCombined"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Combined"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Video A -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIDEO A"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnVideoA"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Select video A"
            android:backgroundTint="@color/card"
            android:textColor="@color/text_primary"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Video B -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIDEO B"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnVideoB"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Select video B"
            android:backgroundTint="@color/card"
            android:textColor="@color/text_primary"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:layout_marginBottom="28dp" />

        <!-- Analyze -->
        <Button
            android:id="@+id/btnAnalyze"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Analyze Similarity"
            android:backgroundTint="@color/primary"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:enabled="false"
            android:layout_marginBottom="24dp" />

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:indeterminateTint="@color/primary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="monospace"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
